{
  "entities": {
    "client": {
      "title": "Cliente",
      "description": "Información de los clientes de la boutique",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Nombre completo" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "balance": { "type": "number", "description": "Saldo del cliente (positivo = deuda, negativo = crédito)" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "bag": {
      "title": "Cartera",
      "description": "Inventario de carteras",
      "type": "object",
      "properties": {
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "condition": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "sold", "concession", "returned"] },
        "price": { "type": "number" },
        "ownerId": { "type": "string", "description": "ID del cliente propietario" },
        "notes": { "type": "string" },
        "photoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["brand", "status"]
    },
    "transaction": {
      "title": "Transacción",
      "description": "Movimientos financieros de clientes",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["payment_received", "payment_made"] },
        "notes": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "amount", "type"]
    },
    "visit": {
      "title": "Visita",
      "description": "Agenda de visitas a clientes",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled"] },
        "purpose": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["clientId", "date", "status"]
    },
    "history": {
      "title": "Historial",
      "description": "Log de actividades del sistema",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "user": {
      "title": "Usuario",
      "description": "Perfiles de administradores",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastActive": { "type": "string", "format": "date-time" },
        "emailVerified": { "type": "boolean" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      }
    }
  },
  "firestore": {
    "/clients/{clientId}": { "schema": "client", "description": "Colección de clientes" },
    "/bags/{bagId}": { "schema": "bag", "description": "Colección de carteras" },
    "/transactions/{transactionId}": { "schema": "transaction", "description": "Historial de pagos y cobranzas" },
    "/visits/{visitId}": { "schema": "visit", "description": "Agenda de visitas" },
    "/history/{historyId}": { "schema": "history", "description": "Log de auditoría" },
    "/users/{userId}": { "schema": "user", "description": "Perfiles de usuario" }
  }
}
