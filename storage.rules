rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Permitir lectura y escritura solo a administradores autenticados
      // andresdavidfr@gmail.com y holalvsm@gmail.com
      allow read, write: if request.auth != null && 
        (request.auth.token.email == "andresdavidfr@gmail.com" || 
         request.auth.token.email == "holalvsm@gmail.com") && 
        request.auth.token.email_verified == true;
    }
  }
}
